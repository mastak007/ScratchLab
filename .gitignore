.scratch_fixture_work/

# Local-only reference / evaluation media (YouTube / external notation
# references, frame extracts, source clips). Off-limits for training per
# SOUL.md / PROFILE.md; never bundled, never scored, never committed.
reference_frames/
reference_videos/
